"""Snakemake workflow: Reproduce MacDonald et al. (2022) GRCh38 LD blocks.

Reproduces the EUR / deCODE analysis and the published pyrho superpopulation
analyses from:
    MacDonald et al. (2022), https://github.com/jmacdon/LDblocks_GRCh38

Pipeline steps:
    0  Data download (VCFs, raw pyrho maps, raw deCODE map, centromeres)
    1  VCF filtering with bcftools (MAF ≥ 0.01, SNPs only)
    2  Individual list preparation (1000G population dirs ∩ VCF samples)
    2a-2c deCODE map conversion/interpolation (the EUR block set uses this
       raw-derived map; validate_maps/compare_maps check it against MacDonald's
       published deCODE_interpolated_maps).
       compare_maps/compare_maps_point_mode together are an interpolation
       equivalence test: ldetect interpolate-maps --mode interval matches
       MacDonald's deCODE interval interpolation and should match their
       published deCODE maps almost exactly, while --mode point (the prior
       default) reproduces the interval-shift bug those scripts fixed -- see
       notes/logs/macdonald2022-interpolation-port.md. pyrho maps are first
       extracted by convert_pyrho_map.py and interpolated with --mode hapmap
       so their cumulative cM is interpreted at HapMap point positions.
    3  LD block detection per chromosome (ldetect run)
    4  Post-processing: centromere removal + small block merging
    5  Genome-wide BED assembly (cat all chromosomes)

Usage:
    cd examples/MacDonald2022/
    uv run snakemake -n                         # dry-run, all chromosomes
    uv run snakemake --cores 8                  # run with 8 parallel jobs
    uv run snakemake --config chromosomes=[22]  # smoke-test on chr22 only
"""

import re
from pathlib import Path

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------


configfile: "config.yaml"


CHROMS = config["chromosomes"]
BLOCK_SETS = list(config["block_sets"].keys())
ACTIVE_BLOCK_SETS = config.get("active_block_sets", BLOCK_SETS)
ACTIVE_PYRHO_MAP_POPS = sorted(
    {
        config["block_sets"][block_set]["map_pop"]
        for block_set in ACTIVE_BLOCK_SETS
        if config["block_sets"][block_set]["map_source"] == "pyrho"
    }
)
LEGACY_DIAGNOSTIC_BLOCK_SETS = config.get("legacy_diagnostics", {}).get(
    "block_sets", []
)
LEGACY_DIAGNOSTIC_CHROMS = [
    str(chrom) for chrom in config.get("legacy_diagnostics", {}).get("chromosomes", [])
]
BLOCK_SET_PATTERN = "|".join(re.escape(block_set) for block_set in BLOCK_SETS)
RAW_DIR = Path(config["raw_vcf_dir"])
FILT_DIR = Path(config["filtered_vcf_dir"])
MAPS_DIR = Path(config["maps_dir"])
RES_DIR = Path(config["resources_dir"])
RESULTS = Path(config["results_dir"])
LEGACY_RESULTS = RESULTS / "legacy_vcf"
VCF_TMPL = config["vcf_filename_template"]


wildcard_constraints:
    reference_bed=r"(deCODE_EUR|pyrho_(AFR|EAS|EUR|SAS))_LD_blocks\.bed",


def pop_ne(population):
    return config["populations"][population]["ne"]


def pop_subpops(population):
    return config["populations"][population]["subpops"]


def block_set_population(block_set):
    return config["block_sets"][block_set]["population"]


def block_set_ne(block_set):
    return pop_ne(block_set_population(block_set))


def block_set_reference_bed(block_set):
    return config["block_sets"][block_set]["reference_bed"]


def diagnostic_resource(filename):
    primary = RES_DIR / filename
    nested = RES_DIR / RES_DIR.name / filename
    if not primary.exists() and nested.exists():
        return str(nested)
    return str(primary)


def block_set_remove_centromeres(block_set):
    return config["block_sets"][block_set].get(
        "remove_centromere_blocks",
        config.get("remove_centromere_blocks", False),
    )


def block_set_maf_filter(block_set):
    """'nref' (default, matches MacDonald's literal bcftools command) or
    'minor' (true minor-allele-frequency filtering, matching MacDonald's
    README prose rather than their script -- see
    notes/logs/macdonald2022-pyrho-handoff.md for why this is worth testing).
    """
    return config["block_sets"][block_set].get("maf_filter", "nref")


def block_set_filtered_vcf(wc):
    if block_set_maf_filter(wc.block_set) == "minor":
        return str(FILT_DIR / "minor" / f"chr{wc.chrom}.vcf.gz")
    return str(FILT_DIR / f"chr{wc.chrom}.vcf.gz")


def block_set_genetic_map(wc):
    block_config = config["block_sets"][wc.block_set]
    if block_config["map_source"] == "decode":
        return str(MAPS_DIR / "interpolated" / f"chr{wc.chrom}.tab.gz")
    if block_config["map_source"] == "pyrho":
        return str(
            MAPS_DIR
            / "pyrho_interpolated_from_raw"
            / block_config["map_pop"]
            / f"chr{wc.chrom}.tab.gz"
        )
    raise ValueError(f"Unknown map source: {block_config['map_source']}")


def expected_individual_count_param(population):
    expected = config["populations"][population].get("expected_count")
    if expected is None:
        return ""
    return f"--expected-count {expected}"


def remove_centromeres_param(wc):
    if block_set_remove_centromeres(wc.block_set):
        return "--remove-centromeres"
    return ""


def legacy_diagnostic_targets(filename):
    return [
        str(LEGACY_RESULTS / block_set / f"chr{chrom}" / "compare" / filename)
        for block_set in LEGACY_DIAGNOSTIC_BLOCK_SETS
        for chrom in LEGACY_DIAGNOSTIC_CHROMS
    ]


# ---------------------------------------------------------------------------
# Target rule
# ---------------------------------------------------------------------------


rule all:
    input:
        expand(
            str(RESULTS / "{block_set}_LD_blocks.bed"),
            block_set=ACTIVE_BLOCK_SETS,
        ),
        expand(
            str(RESULTS / "compare" / "{block_set}_block_comparison.tsv"),
            block_set=ACTIVE_BLOCK_SETS,
        ),
        expand(
            str(
                RESULTS / "compare" / "boundaries" / "{block_set}_boundary_offsets.tsv"
            ),
            block_set=ACTIVE_BLOCK_SETS,
        ),
        expand(
            str(RESULTS / "compare" / "raw" / "{block_set}_block_comparison.tsv"),
            block_set=ACTIVE_BLOCK_SETS,
        ),
        expand(
            str(RESULTS / "compare" / "raw" / "{block_set}_boundary_offsets.tsv"),
            block_set=ACTIVE_BLOCK_SETS,
        ),
        expand(
            str(
                RESULTS
                / "compare"
                / "ld_neighborhood"
                / "{block_set}"
                / "chr{chrom}.svg"
            ),
            block_set=ACTIVE_BLOCK_SETS,
            chrom=CHROMS,
        ),
        expand(
            str(
                RESULTS
                / "compare"
                / "ld_neighborhood"
                / "published"
                / "{block_set}"
                / "chr{chrom}.svg"
            ),
            block_set=ACTIVE_BLOCK_SETS,
            chrom=CHROMS,
        ),
        str(RESULTS / "compare" / "map_summary.tsv"),
        str(RESULTS / "compare" / "map_ref_comparison.tsv"),
        str(RESULTS / "compare" / "map_ref_comparison_point_mode.tsv"),
        expand(
            str(RESULTS / "compare" / "pyrho" / "raw" / "{map_pop}_map_summary.tsv"),
            map_pop=ACTIVE_PYRHO_MAP_POPS,
        ),
        expand(
            str(
                RESULTS
                / "compare"
                / "pyrho"
                / "macdonald"
                / "{map_pop}_map_summary.tsv"
            ),
            map_pop=ACTIVE_PYRHO_MAP_POPS,
        ),
        expand(
            str(
                RESULTS
                / "compare"
                / "pyrho"
                / "macdonald_style"
                / "{map_pop}_map_summary.tsv"
            ),
            map_pop=ACTIVE_PYRHO_MAP_POPS,
        ),
        expand(
            str(
                RESULTS
                / "compare"
                / "pyrho"
                / "macdonald_style_comparison"
                / "{map_pop}_map_ref_comparison.tsv"
            ),
            map_pop=ACTIVE_PYRHO_MAP_POPS,
        ),
        expand(
            str(
                RESULTS
                / "compare"
                / "pyrho"
                / "comparison"
                / "{map_pop}_map_ref_comparison.tsv"
            ),
            map_pop=ACTIVE_PYRHO_MAP_POPS,
        ),


rule legacy_diagnostics:
    input:
        legacy_diagnostic_targets("raw_ldetect_lite_vs_legacy.tsv"),
        legacy_diagnostic_targets("legacy_final_vs_reference.tsv"),


# ---------------------------------------------------------------------------
# Step 0: Download
# ---------------------------------------------------------------------------


rule download_vcf:
    output:
        vcf=str(RAW_DIR / VCF_TMPL).replace("{chrom}", "{chrom}"),
        tbi=str(RAW_DIR / VCF_TMPL).replace("{chrom}", "{chrom}") + ".tbi",
    params:
        base_url=config["vcf_base_url"],
        fname=lambda wc: VCF_TMPL.format(chrom=wc.chrom),
    shell:
        """
        mkdir -p {RAW_DIR}
        wget -q -O {output.vcf} {params.base_url}/{params.fname}
        wget -q -O {output.tbi} {params.base_url}/{params.fname}.tbi
        """


rule download_decode_map:
    output:
        str(MAPS_DIR / "decode_raw" / "aau1043_datas3.gz"),
    params:
        url=config["decode_map_url"],
    shell:
        """
        mkdir -p {MAPS_DIR}/decode_raw
        wget -q -O {output} '{params.url}' || {{
            echo "ERROR: Could not download deCODE map."
            echo "Download manually from: {params.url}"
            echo "Place at: {output}"
            exit 1
        }}
        """


rule download_centromeres:
    output:
        str(RES_DIR / "hg38_centromeres.txt.gz"),
    params:
        url=config["centromere_url"],
    shell:
        "mkdir -p {RES_DIR} && wget -q -O {output} {params.url}"


rule download_pyrho_raw_archive:
    output:
        str(MAPS_DIR / "pyrho_raw" / "hg38_maps.tar.gz"),
    params:
        url=config["pyrho_raw_map_url"],
    shell:
        """
        mkdir -p {MAPS_DIR}/pyrho_raw
        wget -q -O {output} '{params.url}'
        """


rule convert_pyrho_map:
    input:
        rules.download_pyrho_raw_archive.output[0],
    output:
        str(MAPS_DIR / "pyrho_raw" / "{map_pop}" / "chr{chrom}.tab.gz"),
    shell:
        """
        uv run python scripts/convert_pyrho_map.py \
            --archive {input} \
            --population {wildcards.map_pop} \
            --chromosome {wildcards.chrom} \
            --output {output}
        """


rule download_macdonald_pyrho_map:
    output:
        str(
            MAPS_DIR
            / "macdonald_pyrho_interpolated_maps"
            / "{map_pop}"
            / "chr{chrom}.tab.gz"
        ),
    params:
        base_url=config["macdonald_pyrho_map_base_url"],
    shell:
        """
        mkdir -p {MAPS_DIR}/macdonald_pyrho_interpolated_maps/{wildcards.map_pop}
        wget -q -O {output} \
            {params.base_url}/{wildcards.map_pop}/chr{wildcards.chrom}.tab.gz
        """


# MacDonald et al. also publish their own already-interpolated deCODE maps
# (same chr/pos/cM format as the pyrho maps above), produced by their own R
# interpolation script. Keep these as comparison targets; the EUR/deCODE block
# set itself uses the raw-derived interpolation from convert_decode_map.
rule download_decode_interpolated_map:
    output:
        str(MAPS_DIR / "decode_interpolated_maps" / "chr{chrom}.tab.gz"),
    params:
        base_url=config["decode_interpolated_map_base_url"],
    shell:
        """
        mkdir -p {MAPS_DIR}/decode_interpolated_maps
        wget -q -O {output} {params.base_url}/chr{wildcards.chrom}.tab.gz
        """


# ---------------------------------------------------------------------------
# Step 1: Filter VCFs
# ---------------------------------------------------------------------------


rule filter_vcf:
    input:
        vcf=str(RAW_DIR / VCF_TMPL).replace("{chrom}", "{chrom}"),
        tbi=str(RAW_DIR / VCF_TMPL).replace("{chrom}", "{chrom}") + ".tbi",
    output:
        vcf=str(FILT_DIR / "chr{chrom}.vcf.gz"),
        tbi=str(FILT_DIR / "chr{chrom}.vcf.gz.tbi"),
    shell:
        """
        mkdir -p {FILT_DIR}
        bcftools view --min-af 0.01 --types snps -Oz -o {output.vcf} {input.vcf}
        bcftools index --tbi {output.vcf}
        """


# Experimental variant: MacDonald's README says they filter by "MAF>0.01",
# but their actual subsetVcf.sh runs plain `--min-af 0.01` with no `:minor`
# suffix, which bcftools defaults to non-reference (nref, effectively ALT)
# allele frequency, not minor allele frequency. This rule tests the prose's
# literal meaning instead. Kept as a fully separate output path (not a
# parameterized version of filter_vcf above) so it never invalidates or
# forces recomputation of the already-validated default-filtered pipeline --
# opt-in only via a block_set with `maf_filter: minor` in config.yaml, never
# part of `active_block_sets`. `:minor` and `:nonmajor` are numerically
# identical for this biallelic-SNV 1000G release, so only one is needed.
rule filter_vcf_minor:
    input:
        vcf=str(RAW_DIR / VCF_TMPL).replace("{chrom}", "{chrom}"),
        tbi=str(RAW_DIR / VCF_TMPL).replace("{chrom}", "{chrom}") + ".tbi",
    output:
        vcf=str(FILT_DIR / "minor" / "chr{chrom}.vcf.gz"),
        tbi=str(FILT_DIR / "minor" / "chr{chrom}.vcf.gz.tbi"),
    shell:
        """
        mkdir -p {FILT_DIR}/minor
        bcftools view --min-af 0.01:minor --types snps -Oz -o {output.vcf} {input.vcf}
        bcftools index --tbi {output.vcf}
        """


# ---------------------------------------------------------------------------
# Step 2: Individual list
# ---------------------------------------------------------------------------


rule prep_individuals:
    input:
        vcf=str(FILT_DIR / "chr22.vcf.gz"),  # any chromosome suffices
    output:
        str(RES_DIR / "{population}_inds.txt"),
    params:
        subpops=lambda wc: " ".join(pop_subpops(wc.population)),
        base_url=config["sample_data_base_url"],
        expected_count=lambda wc: expected_individual_count_param(wc.population),
    shell:
        """
        uv run python scripts/prep_individuals.py \
            --sample-data-base-url {params.base_url} \
            --subpops {params.subpops} \
            --vcf {input.vcf} \
            --output {output} \
            {params.expected_count}
        """


# ---------------------------------------------------------------------------
# Step 2a: Convert deCODE map to 3-column per chromosome
# ---------------------------------------------------------------------------


rule convert_decode_map:
    input:
        rules.download_decode_map.output[0],
    output:
        str(MAPS_DIR / "decode_raw" / "chr{chrom}.tab.gz"),
    shell:
        """
        uv run python scripts/convert_decode_map.py \
            --input {input} \
            --output-dir {MAPS_DIR}/decode_raw \
            --chromosomes {wildcards.chrom}
        """


# ---------------------------------------------------------------------------
# Step 2b: Extract SNP positions from filtered VCF
# ---------------------------------------------------------------------------


rule extract_snp_positions:
    input:
        str(FILT_DIR / "chr{chrom}.vcf.gz"),
    output:
        str(MAPS_DIR / "snps" / "chr{chrom}.bed.gz"),
    shell:
        """
        mkdir -p {MAPS_DIR}/snps
        bcftools query -f '%CHROM\t%POS0\t%POS\t%ID\n' {input} | bgzip > {output}
        """


# ---------------------------------------------------------------------------
# Step 2c: Interpolate genetic maps
# ---------------------------------------------------------------------------


rule interpolate_map:
    input:
        snps=rules.extract_snp_positions.output[0],
        map=rules.convert_decode_map.output[0],
    output:
        str(MAPS_DIR / "interpolated" / "chr{chrom}.tab.gz"),
    shell:
        """
        mkdir -p {MAPS_DIR}/interpolated
        uv run ldetect interpolate-maps \
            --snp-file {input.snps} \
            --genetic-map {input.map} \
            --output {output} \
            --mode interval
        """


# Point-mode counterpart of interpolate_map, kept only so compare_maps_point
# can quantify the interpolation bug --mode interval fixed: feeding
# convert_decode_map.py's interval-rate rows into point-based interpolation
# uses the *next* interval's rate for SNPs in the *current* interval. See
# notes/logs/macdonald2022-interpolation-port.md.
rule interpolate_map_point:
    input:
        snps=rules.extract_snp_positions.output[0],
        map=rules.convert_decode_map.output[0],
    output:
        str(MAPS_DIR / "interpolated_point" / "chr{chrom}.tab.gz"),
    shell:
        """
        mkdir -p {MAPS_DIR}/interpolated_point
        uv run ldetect interpolate-maps \
            --snp-file {input.snps} \
            --genetic-map {input.map} \
            --output {output} \
            --mode point
        """


rule interpolate_pyrho_map:
    input:
        snps=rules.extract_snp_positions.output[0],
        map=rules.convert_pyrho_map.output[0],
    output:
        str(MAPS_DIR / "pyrho_interpolated_from_raw" / "{map_pop}" / "chr{chrom}.tab.gz"),
    shell:
        """
        mkdir -p {MAPS_DIR}/pyrho_interpolated_from_raw/{wildcards.map_pop}
        uv run ldetect interpolate-maps \
            --snp-file {input.snps} \
            --genetic-map {input.map} \
            --output {output} \
            --mode hapmap
        """


rule interpolate_pyrho_map_macdonald_style:
    input:
        snps=rules.extract_snp_positions.output[0],
        map=rules.convert_pyrho_map.output[0],
    output:
        str(
            MAPS_DIR
            / "pyrho_interpolated_macdonald_style"
            / "{map_pop}"
            / "chr{chrom}.tab.gz"
        ),
    shell:
        """
        mkdir -p {MAPS_DIR}/pyrho_interpolated_macdonald_style/{wildcards.map_pop}
        uv run ldetect interpolate-maps \
            --snp-file {input.snps} \
            --genetic-map {input.map} \
            --output {output} \
            --mode interval
        """


# ---------------------------------------------------------------------------
# Step 3: Run ldetect-lite per chromosome × block set
#
# The shared ldetect-lite covariance code applies the covariance cutoff before
# adding the diagonal shrinkage term, matching original ldetect behavior and
# preventing population-monomorphic variants from entering the covariance
# output. deCODE and pyrho block sets use locally interpolated maps derived
# from the raw map sources; MacDonald's published maps are comparison targets.
# ---------------------------------------------------------------------------


rule run_ldetect:
    input:
        genetic_map=block_set_genetic_map,
        vcf=block_set_filtered_vcf,
        individuals=lambda wc: str(
            RES_DIR / f"{block_set_population(wc.block_set)}_inds.txt"
        ),
    output:
        bed=str(RESULTS / "{block_set}" / "chr{chrom}" / "chr{chrom}-ld-blocks.bed"),
        vector=str(RESULTS / "{block_set}" / "chr{chrom}" / "vector-chr{chrom}.txt.gz"),
        breakpoints=str(
            RESULTS / "{block_set}" / "chr{chrom}" / "breakpoints-chr{chrom}.json"
        ),
        partitions=str(
            RESULTS / "{block_set}" / "chr{chrom}" / "chr{chrom}_partitions.txt"
        ),
    log:
        run=str(RESULTS / "logs" / "{block_set}" / "chr{chrom}.ldetect.log"),
        timing=str(RESULTS / "logs" / "{block_set}" / "chr{chrom}.timing.log"),
    benchmark:
        str(RESULTS / "logs" / "{block_set}" / "chr{chrom}.benchmark.tsv")
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    threads: config["workers"]
    params:
        output_dir=str(RESULTS / "{block_set}" / "chr{chrom}"),
        log_dir=str(RESULTS / "logs" / "{block_set}"),
        ne=lambda wc: block_set_ne(wc.block_set),
        cutoff=config["cov_cutoff"],
        subset=config["subset"],
        n_snps_bw_bpoints=config["n_snps_bw_bpoints"],
    shell:
        """
        mkdir -p {params.log_dir}
        export OMP_NUM_THREADS={threads}
        export OPENBLAS_NUM_THREADS={threads}
        export MKL_NUM_THREADS={threads}
        export NUMEXPR_NUM_THREADS={threads}
        export NUMBA_NUM_THREADS={threads}
        /usr/bin/time -v -o {log.timing} \
        uv run ldetect run \
            --genetic-map {input.genetic_map} \
            --reference-panel {input.vcf} \
            --individuals {input.individuals} \
            --chromosome chr{wildcards.chrom} \
            --output-dir {params.output_dir} \
            --ne {params.ne} \
            --cov-cutoff {params.cutoff} \
            --n-snps-bw-bpoints {params.n_snps_bw_bpoints} \
            --subset {params.subset} \
            --workers {threads} \
            > {log.run} 2>&1
        """


# ---------------------------------------------------------------------------
# Step 4: Post-processing
# ---------------------------------------------------------------------------


rule postprocess:
    input:
        bed=rules.run_ldetect.output.bed,
        vcf=block_set_filtered_vcf,
        centromeres=rules.download_centromeres.output[0],
    output:
        str(RESULTS / "{block_set}" / "chr{chrom}" / "chr{chrom}-ld-blocks.final.bed"),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    params:
        min_snps=config["min_snps_per_block"],
        remove_centromeres=remove_centromeres_param,
    shell:
        """
        uv run python scripts/postprocess.py \
            --bed {input.bed} \
            --vcf {input.vcf} \
            --centromeres {input.centromeres} \
            {params.remove_centromeres} \
            --min-snps {params.min_snps} \
            --output {output}
        """


rule plot_ld_neighborhood_separation:
    input:
        bed=rules.postprocess.output[0],
        partitions=rules.run_ldetect.output.partitions,
    output:
        tsv=str(
            RESULTS
            / "compare"
            / "ld_neighborhood"
            / "{block_set}"
            / "chr{chrom}.tsv"
        ),
        plot=str(
            RESULTS
            / "compare"
            / "ld_neighborhood"
            / "{block_set}"
            / "chr{chrom}.svg"
        ),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    params:
        covariance_root=str(RESULTS / "{block_set}" / "chr{chrom}"),
        window_bp=config.get("ld_neighborhood_window_bp", 500_000),
        sample_limit=config.get("ld_neighborhood_sample_limit", 200_000),
    shell:
        """
        uv run python scripts/plot_ld_neighborhood_separation.py \
            --bed {input.bed} \
            --covariance-root {params.covariance_root} \
            --chrom chr{wildcards.chrom} \
            --output-tsv {output.tsv} \
            --plot {output.plot} \
            --window-bp {params.window_bp} \
            --sample-limit {params.sample_limit} \
            --title "{wildcards.block_set} chr{wildcards.chrom}: LD neighborhood separation"
        """


rule plot_published_ld_neighborhood_separation:
    input:
        bed=lambda wc: str(RES_DIR / block_set_reference_bed(wc.block_set)),
        partitions=rules.run_ldetect.output.partitions,
    output:
        tsv=str(
            RESULTS
            / "compare"
            / "ld_neighborhood"
            / "published"
            / "{block_set}"
            / "chr{chrom}.tsv"
        ),
        plot=str(
            RESULTS
            / "compare"
            / "ld_neighborhood"
            / "published"
            / "{block_set}"
            / "chr{chrom}.svg"
        ),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    params:
        covariance_root=str(RESULTS / "{block_set}" / "chr{chrom}"),
        window_bp=config.get("ld_neighborhood_window_bp", 500_000),
        sample_limit=config.get("ld_neighborhood_sample_limit", 200_000),
    shell:
        """
        uv run python scripts/plot_ld_neighborhood_separation.py \
            --bed {input.bed} \
            --covariance-root {params.covariance_root} \
            --chrom chr{wildcards.chrom} \
            --output-tsv {output.tsv} \
            --plot {output.plot} \
            --window-bp {params.window_bp} \
            --sample-limit {params.sample_limit} \
            --title "published {wildcards.block_set} chr{wildcards.chrom}: LD neighborhood separation"
        """


# ---------------------------------------------------------------------------
# Opt-in diagnostic: vendored legacy ldetect on the same MacDonald inputs
# ---------------------------------------------------------------------------


rule run_legacy_from_vcf:
    input:
        genetic_map=block_set_genetic_map,
        vcf=block_set_filtered_vcf,
        tbi=lambda wc: block_set_filtered_vcf(wc) + ".tbi",
        individuals=lambda wc: str(
            RES_DIR / f"{block_set_population(wc.block_set)}_inds.txt"
        ),
        runner="scripts/run_legacy_from_vcf.py",
    output:
        bed=str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "legacy"
            / "chr{chrom}-ld-blocks.bed"
        ),
        vector=str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "legacy"
            / "vector-chr{chrom}.txt.gz"
        ),
        breakpoints=str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "legacy"
            / "breakpoints-chr{chrom}.json"
        ),
        summary=str(
            LEGACY_RESULTS / "{block_set}" / "chr{chrom}" / "legacy" / "summary.tsv"
        ),
        partitions=str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "legacy_dataset"
            / "scripts"
            / "chr{chrom}_partitions"
        ),
    log:
        run=str(LEGACY_RESULTS / "{block_set}" / "chr{chrom}" / "logs" / "legacy.log"),
        timing=str(
            LEGACY_RESULTS / "{block_set}" / "chr{chrom}" / "logs" / "legacy.timing.log"
        ),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    params:
        output_dir=str(LEGACY_RESULTS / "{block_set}" / "chr{chrom}"),
        log_dir=str(LEGACY_RESULTS / "{block_set}" / "chr{chrom}" / "logs"),
        ne=lambda wc: block_set_ne(wc.block_set),
        cutoff=config["cov_cutoff"],
        subset=config["subset"],
        n_snps_bw_bpoints=config["n_snps_bw_bpoints"],
    shell:
        """
        mkdir -p {params.log_dir}
        /usr/bin/time -v -o {log.timing} \
        uv run python {input.runner} \
            --genetic-map {input.genetic_map} \
            --vcf {input.vcf} \
            --individuals {input.individuals} \
            --chromosome chr{wildcards.chrom} \
            --block-set {wildcards.block_set} \
            --output-dir {params.output_dir} \
            --ne {params.ne} \
            --cov-cutoff {params.cutoff} \
            --n-snps-bw-bpoints {params.n_snps_bw_bpoints} \
            --subset {params.subset} \
            > {log.run} 2>&1
        """


rule postprocess_legacy_from_vcf:
    input:
        bed=rules.run_legacy_from_vcf.output.bed,
        vcf=block_set_filtered_vcf,
        centromeres=rules.download_centromeres.output[0],
    output:
        str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "legacy"
            / "chr{chrom}-ld-blocks.final.bed"
        ),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    params:
        min_snps=config["min_snps_per_block"],
        remove_centromeres=remove_centromeres_param,
    shell:
        """
        uv run python scripts/postprocess.py \
            --bed {input.bed} \
            --vcf {input.vcf} \
            --centromeres {input.centromeres} \
            {params.remove_centromeres} \
            --min-snps {params.min_snps} \
            --output {output}
        """


rule compare_legacy_from_vcf:
    input:
        ldetect_lite_vector=rules.run_ldetect.output.vector,
        legacy_vector=rules.run_legacy_from_vcf.output.vector,
        ldetect_lite_breakpoints=rules.run_ldetect.output.breakpoints,
        legacy_breakpoints=rules.run_legacy_from_vcf.output.breakpoints,
        ldetect_lite_raw_bed=rules.run_ldetect.output.bed,
        legacy_raw_bed=rules.run_legacy_from_vcf.output.bed,
        legacy_final_bed=rules.postprocess_legacy_from_vcf.output[0],
        reference_bed=lambda wc: str(RES_DIR / block_set_reference_bed(wc.block_set)),
        script="scripts/compare_legacy_stage_outputs.py",
    output:
        raw_ldetect_lite_vs_legacy=str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "compare"
            / "raw_ldetect_lite_vs_legacy.tsv"
        ),
        legacy_final_vs_reference=str(
            LEGACY_RESULTS
            / "{block_set}"
            / "chr{chrom}"
            / "compare"
            / "legacy_final_vs_reference.tsv"
        ),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    params:
        subset=config["subset"],
        tolerance=config.get("legacy_diagnostics", {}).get("tolerance", 50_000),
    shell:
        """
        uv run python {input.script} \
            --chromosome chr{wildcards.chrom} \
            --ldetect-lite-vector {input.ldetect_lite_vector} \
            --legacy-vector {input.legacy_vector} \
            --ldetect-lite-breakpoints {input.ldetect_lite_breakpoints} \
            --legacy-breakpoints {input.legacy_breakpoints} \
            --ldetect-lite-raw-bed {input.ldetect_lite_raw_bed} \
            --legacy-raw-bed {input.legacy_raw_bed} \
            --legacy-final-bed {input.legacy_final_bed} \
            --reference-bed {input.reference_bed} \
            --subset {params.subset} \
            --tolerance {params.tolerance} \
            --raw-ldetect-lite-vs-legacy {output.raw_ldetect_lite_vs_legacy} \
            --legacy-final-vs-reference {output.legacy_final_vs_reference}
        """


# ---------------------------------------------------------------------------
# Step 5: Combine chromosomes into genome-wide BED
# ---------------------------------------------------------------------------


rule combine_raw_beds:
    input:
        expand(
            str(RESULTS / "{{block_set}}" / "chr{chrom}" / "chr{chrom}-ld-blocks.bed"),
            chrom=CHROMS,
        ),
    output:
        str(RESULTS / "{block_set}_raw_LD_blocks.bed"),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    shell:
        """
        # Write header once, then body lines from all chromosomes (skip per-file headers)
        echo -e "#chr\tstart\tstop" > {output}
        for f in {input}; do
            tail -n +2 "$f" >> {output}
        done
        """


rule combine_beds:
    input:
        expand(
            str(
                RESULTS
                / "{{block_set}}"
                / "chr{chrom}"
                / "chr{chrom}-ld-blocks.final.bed"
            ),
            chrom=CHROMS,
        ),
    output:
        str(RESULTS / "{block_set}_LD_blocks.bed"),
    wildcard_constraints:
        block_set=BLOCK_SET_PATTERN,
    shell:
        """
        # Write header once, then body lines from all chromosomes (skip per-file headers)
        echo -e "#chr\tstart\tstop" > {output}
        for f in {input}; do
            tail -n +2 "$f" >> {output}
        done
        """


# ---------------------------------------------------------------------------
# Step 6a: Validate interpolated genetic maps
# ---------------------------------------------------------------------------


rule validate_maps:
    input:
        expand(
            str(MAPS_DIR / "interpolated" / "chr{chrom}.tab.gz"),
            chrom=CHROMS,
        ),
    output:
        str(RESULTS / "compare" / "map_summary.tsv"),
    shell:
        """
        uv run python scripts/validate_maps.py \
            --interpolated {input} \
            --output {output}
        """


rule compare_maps:
    input:
        expand(
            str(MAPS_DIR / "interpolated" / "chr{chrom}.tab.gz"),
            chrom=CHROMS,
        ),
    output:
        str(RESULTS / "compare" / "map_ref_comparison.tsv"),
    params:
        ref_dir=str(RES_DIR / "macdonalds_maps"),
    shell:
        """
        uv run python scripts/compare_maps.py \
            --ours {input} \
            --ref-dir {params.ref_dir} \
            --output {output}
        """


# Equivalence check for deCODE maps: --mode interval matches MacDonald's
# deCODE interval-rate interpolation, so it should match their published
# deCODE_interpolated_maps almost exactly (near-zero MAE). This rule reruns
# the same comparison against interpolate_map_point's --mode point output so
# the two map_ref_comparison*.tsv files can be diffed directly: interval
# mode's MAE should collapse to ~0 while point mode reproduces the
# previously measured 0.0013-0.0026 cM error. pyrho maps are intentionally
# excluded from this equivalence claim because their HapMap-style cumulative
# coordinates are handled by --mode hapmap. See
# notes/logs/macdonald2022-interpolation-port.md.
rule compare_maps_point_mode:
    input:
        expand(
            str(MAPS_DIR / "interpolated_point" / "chr{chrom}.tab.gz"),
            chrom=CHROMS,
        ),
    output:
        str(RESULTS / "compare" / "map_ref_comparison_point_mode.tsv"),
    params:
        ref_dir=str(RES_DIR / "macdonalds_maps"),
    shell:
        """
        uv run python scripts/compare_maps.py \
            --ours {input} \
            --ref-dir {params.ref_dir} \
            --output {output}
        """


rule validate_pyrho_maps:
    input:
        lambda wc: expand(
            str(MAPS_DIR / "pyrho_interpolated_from_raw" / wc.map_pop / "chr{chrom}.tab.gz"),
            chrom=CHROMS,
        ),
    output:
        str(RESULTS / "compare" / "pyrho" / "raw" / "{map_pop}_map_summary.tsv"),
    shell:
        """
        uv run python scripts/validate_maps.py \
            --interpolated {input} \
            --output {output}
        """


rule validate_macdonald_pyrho_maps:
    input:
        lambda wc: expand(
            str(
                MAPS_DIR
                / "macdonald_pyrho_interpolated_maps"
                / wc.map_pop
                / "chr{chrom}.tab.gz"
            ),
            chrom=CHROMS,
        ),
    output:
        str(
            RESULTS / "compare" / "pyrho" / "macdonald" / "{map_pop}_map_summary.tsv"
        ),
    shell:
        """
        uv run python scripts/validate_maps.py \
            --interpolated {input} \
            --output {output}
        """


rule compare_pyrho_maps:
    input:
        lambda wc: expand(
            str(MAPS_DIR / "pyrho_interpolated_from_raw" / wc.map_pop / "chr{chrom}.tab.gz"),
            chrom=CHROMS,
        ),
    output:
        str(
            RESULTS
            / "compare"
            / "pyrho"
            / "comparison"
            / "{map_pop}_map_ref_comparison.tsv"
        ),
    params:
        ref_dir=lambda wc: str(
            MAPS_DIR / "macdonald_pyrho_interpolated_maps" / wc.map_pop
        ),
        ref_url=lambda wc: (
            config["macdonald_pyrho_map_base_url"].rstrip("/")
            + f"/{wc.map_pop}/chr{{chrom}}.tab.gz"
        ),
    shell:
        """
        uv run python scripts/compare_maps.py \
            --ours {input} \
            --ref-dir {params.ref_dir} \
            --ref-url-template '{params.ref_url}' \
            --output {output}
        """


rule validate_pyrho_maps_macdonald_style:
