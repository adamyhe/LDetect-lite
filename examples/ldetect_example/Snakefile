"""Snakemake workflow: Reproduce the ldetect example analysis.

Reproduces the original ldetect EUR chr2 example from:
    Berisa & Pickrell (2016), https://bitbucket.org/nygcresearch/ldetect

Reference downstream intermediates are downloaded from BitBucket. The workflow
fetches the matching 1000 Genomes Phase 1 interval, filters it to the example
EUR individuals, computes covariance from the VCF, and compares each downstream
stage to the original LDetect artifacts.

Pipeline steps:
    0  Download reference intermediates from BitBucket
    1  Fetch/filter the matching 1000G VCF interval
    2  Compute covariance from VCF (uint8 reference backend for full-schema exactness)
    3  Stage reference partition file
    4  Run matrix-to-vector   (compare vs reference vector)
    5  Run find-minima         (compare vs reference breakpoints)
    6  Run extract-bpoints     (compare vs reference BED)
    7  Run partition-chromosome with reference genetic map
       (note: reference file has only 1 window; full-chr2 output won't match)
    8  Aggregate comparison report

Usage:
    cd examples/ldetect_example/
    uv run snakemake -n               # dry-run
    uv run snakemake --cores 4        # run
"""

from pathlib import Path

configfile: "config.yaml"

CHROM     = config["chromosome"]
VCF_CHROM = CHROM[3:] if str(CHROM).startswith("chr") else CHROM
START     = config["region_start"]
END       = config["region_end"]
N_INDS    = config["n_individuals"]
NE        = config["ne"]
COV_CUTOFF = config["cov_cutoff"]
N_SNPS    = config["n_snps_bw_bpoints"]
SUBSET    = config["subset"]
BB_BASE   = config["bitbucket_base"]

REF_DIR   = Path(config["ref_dir"])
WORK_DIR  = Path(config["work_dir"])
RES_DIR   = Path(config["results_dir"])

# Reference file paths (downloaded from BitBucket)
REF_COV_GZ   = REF_DIR / f"cov_matrix/{CHROM}/{CHROM}.{START}.{END}.gz"
REF_PARTS    = REF_DIR / f"cov_matrix/scripts/{CHROM}_partitions"
REF_MAP      = REF_DIR / f"{CHROM}.interpolated_genetic_map.gz"
REF_INDS     = REF_DIR / "eurinds.txt"
REF_VECTOR   = REF_DIR / f"vector/vector-EUR-{CHROM}-{START}-{END}.txt.gz"
REF_BPOINTS  = REF_DIR / f"minima/minima-EUR-{CHROM}-{N_SNPS}-{START}-{END}.pickle"
REF_BED      = REF_DIR / f"bed/EUR-{CHROM}-{N_SNPS}-{START}-{END}.bed"

# Our pipeline outputs
WORK_H5     = WORK_DIR / f"{CHROM}/{CHROM}.{START}.{END}.h5"
WORK_VCF    = WORK_DIR / f"vcf/1000G.phase1.EUR.{VCF_CHROM}.{START}-{END}.vcf.gz"
WORK_BCF    = WORK_DIR / f"vcf/1000G.phase1.EUR.{VCF_CHROM}.{START}-{END}.bcf"
WORK_PARTS  = WORK_DIR / f"{CHROM}_partitions.txt"
WORK_VECTOR = WORK_DIR / f"vector-{CHROM}.txt.gz"
WORK_BPTS   = WORK_DIR / f"breakpoints-{CHROM}.json"
WORK_BED    = WORK_DIR / f"{CHROM}-ld-blocks.bed"
WORK_GEN_PARTS = WORK_DIR / f"generated_partitions/{CHROM}_partitions"
PLOTS_DIR = RES_DIR / "plots"
MPLCONFIG_DIR = RES_DIR / ".mplconfig"
XDG_CACHE_DIR = RES_DIR / ".cache"


# ---------------------------------------------------------------------------
# Target rule
# ---------------------------------------------------------------------------

rule all:
    input:
        str(RES_DIR / "compare_covariance.tsv"),
        str(RES_DIR / "compare_staged_partitions.tsv"),
        str(RES_DIR / "compare_vector.tsv"),
        str(RES_DIR / "compare_bpoints.tsv"),
        str(RES_DIR / "compare_bed.tsv"),
        str(RES_DIR / "compare_generated_partitions.tsv"),
        str(PLOTS_DIR / "covariance.svg"),
        str(PLOTS_DIR / "vector.svg"),
        str(PLOTS_DIR / "breakpoints.svg"),
        str(PLOTS_DIR / "bed.svg"),
        str(PLOTS_DIR / "generated_partitions.svg"),


# ---------------------------------------------------------------------------
# Step 0: Download reference data from BitBucket
# ---------------------------------------------------------------------------

rule download_ref:
    output:
        cov_gz   = str(REF_COV_GZ),
        parts    = str(REF_PARTS),
        map_     = str(REF_MAP),
        inds     = str(REF_INDS),
        vector   = str(REF_VECTOR),
        bpoints  = str(REF_BPOINTS),
        bed      = str(REF_BED),
    params:
        base = BB_BASE,
        chrom = CHROM,
        start = START,
        end   = END,
        n     = N_SNPS,
    shell:
        """
        mkdir -p {REF_DIR}/cov_matrix/{params.chrom} \
                 {REF_DIR}/cov_matrix/scripts \
                 {REF_DIR}/vector \
                 {REF_DIR}/minima \
                 {REF_DIR}/bed

        wget -q -O {output.cov_gz}  "{params.base}/cov_matrix/{params.chrom}/{params.chrom}.{params.start}.{params.end}.gz"
        wget -q -O {output.parts}   "{params.base}/cov_matrix/scripts/{params.chrom}_partitions"
        wget -q -O {output.map_}    "{params.base}/{params.chrom}.interpolated_genetic_map.gz"
        wget -q -O {output.inds}    "{params.base}/eurinds.txt"
        wget -q -O {output.vector}  "{params.base}/vector/vector-EUR-{params.chrom}-{params.start}-{params.end}.txt.gz"
        wget -q -O {output.bpoints} "{params.base}/minima/minima-EUR-{params.chrom}-{params.n}-{params.start}-{params.end}.pickle"
        wget -q -O {output.bed}     "{params.base}/bed/EUR-{params.chrom}-{params.n}-{params.start}-{params.end}.bed"
        """


# ---------------------------------------------------------------------------
# Step 1: Fetch/filter 1000G VCF
# ---------------------------------------------------------------------------

rule prepare_1000g_vcf:
    input:
        individuals = str(REF_INDS),
    output:
        vcf = str(WORK_VCF),
        tbi = str(WORK_VCF) + ".tbi",
        bcf = str(WORK_BCF),
        csi = str(WORK_BCF) + ".csi",
    shell:
        """
        uv run python scripts/prepare_1000g_region.py \
            --individuals {input.individuals} \
            --chrom {VCF_CHROM} \
            --start {START} \
            --end {END} \
            --output-vcf {output.vcf} \
            --output-bcf {output.bcf}
        """


# ---------------------------------------------------------------------------
# Step 2: Calculate covariance from VCF.
#
# The toy covariance exactness check compares full-schema legacy fields, so this
# rule deliberately uses the uint8 reference backend rather than the production
# bitpacked default.
# ---------------------------------------------------------------------------

rule calc_covariance:
    input:
        vcf = str(WORK_VCF),
        tbi = str(WORK_VCF) + ".tbi",
        genetic_map = str(REF_MAP),
        individuals = str(REF_INDS),
    output:
        str(WORK_H5),
    shell:
        """
        mkdir -p $(dirname {output})
        export OMP_NUM_THREADS=1
        export OPENBLAS_NUM_THREADS=1
        export MKL_NUM_THREADS=1
        export NUMEXPR_NUM_THREADS=1
        export NUMBA_NUM_THREADS=1
        uv run ldetect calc-covariance \
            --reference-panel {input.vcf} \
            --region {VCF_CHROM}:{START}-{END} \
            --genetic-map {input.genetic_map} \
            --individuals {input.individuals} \
            --output {output} \
            --ne {NE} \
            --cutoff {COV_CUTOFF} \
            --ld-kernel uint8
        """


# ---------------------------------------------------------------------------
# Step 2: Stage reference partition file
# ---------------------------------------------------------------------------

rule stage_ref_partitions:
    input:
        str(REF_PARTS),
    output:
        str(WORK_PARTS),
    shell:
        "mkdir -p $(dirname {output}) && cp {input} {output}"


# ---------------------------------------------------------------------------
# Step 3: Matrix → vector
# ---------------------------------------------------------------------------

rule matrix_to_vector:
    input:
        h5    = str(WORK_H5),
        parts = str(WORK_PARTS),
    output:
        str(WORK_VECTOR),
    shell:
        """
        export OMP_NUM_THREADS=1
        export OPENBLAS_NUM_THREADS=1
        export MKL_NUM_THREADS=1
        export NUMEXPR_NUM_THREADS=1
        export NUMBA_NUM_THREADS=1
        uv run ldetect matrix-to-vector \
            --dataset-path {WORK_DIR} \
            --name {CHROM} \
            --output {output}
        """


# ---------------------------------------------------------------------------
# Step 4: Find minima
# ---------------------------------------------------------------------------

rule find_minima:
    input:
        vector = str(WORK_VECTOR),
        parts  = str(WORK_PARTS),
    output:
        str(WORK_BPTS),
    shell:
        """
        export OMP_NUM_THREADS=1
        export OPENBLAS_NUM_THREADS=1
        export MKL_NUM_THREADS=1
        export NUMEXPR_NUM_THREADS=1
        export NUMBA_NUM_THREADS=1
        uv run ldetect find-minima \
            --input {input.vector} \
            --chr-name {CHROM} \
            --dataset-path {WORK_DIR} \
            --n-snps-bw-bpoints {N_SNPS} \
            --output {output}
        """


# ---------------------------------------------------------------------------
# Step 5: Extract breakpoints → BED
# ---------------------------------------------------------------------------

rule extract_bpoints:
    input:
        bpts  = str(WORK_BPTS),
        parts = str(WORK_PARTS),
    output:
        str(WORK_BED),
    shell:
        """
        uv run ldetect extract-bpoints \
            --name {CHROM} \
            --dataset-path {WORK_DIR} \
            --breakpoints {input.bpts} \
            --subset {SUBSET} \
            --output {output}
        """


# ---------------------------------------------------------------------------
# Step 6: Re-run partition-chromosome (independent check)
# ---------------------------------------------------------------------------

rule partition_chromosome:
    input:
        str(REF_MAP),
    output:
        str(WORK_GEN_PARTS),
    shell:
        """
        mkdir -p $(dirname {output})
        uv run ldetect partition-chromosome \
            --genetic-map {input} \
            --n-individuals {N_INDS} \
            --ne {NE} \
            --output {output}
        """


# ---------------------------------------------------------------------------
# Step 7: Comparisons
# ---------------------------------------------------------------------------

rule compare_vector:
    input:
        ours = str(WORK_VECTOR),
        ref  = str(REF_VECTOR),
    output:
        tsv = str(RES_DIR / "compare_vector.tsv"),
        plot = str(PLOTS_DIR / "vector.svg"),
    shell:
        """
        mkdir -p {RES_DIR} {PLOTS_DIR} {MPLCONFIG_DIR} {XDG_CACHE_DIR}
        export MPLCONFIGDIR="$PWD/{MPLCONFIG_DIR}"
        export XDG_CACHE_HOME="$PWD/{XDG_CACHE_DIR}"
        uv run --extra heatmap python scripts/compare_vector.py \
            --ours {input.ours} \
            --ref  {input.ref} \
            --output {output.tsv} \
            --plot {output.plot} \
            --atol 1e-12 \
            --require-equivalent
        """


rule compare_covariance:
    input:
        ours = str(WORK_H5),
        ref = str(REF_COV_GZ),
    output:
        tsv = str(RES_DIR / "compare_covariance.tsv"),
        plot = str(PLOTS_DIR / "covariance.svg"),
    shell:
        """
        mkdir -p {RES_DIR} {PLOTS_DIR} {MPLCONFIG_DIR} {XDG_CACHE_DIR}
        export MPLCONFIGDIR="$PWD/{MPLCONFIG_DIR}"
        export XDG_CACHE_HOME="$PWD/{XDG_CACHE_DIR}"
        uv run --extra heatmap python scripts/compare_covariance.py \
            --ours {input.ours} \
            --ref {input.ref} \
            --output {output.tsv} \
            --plot {output.plot} \
            --atol 1e-12 \
            --require-equivalent
        """


rule compare_bpoints:
    input:
        ours = str(WORK_BPTS),
        ref  = str(REF_BPOINTS),
    output:
        tsv = str(RES_DIR / "compare_bpoints.tsv"),
        plot = str(PLOTS_DIR / "breakpoints.svg"),
    shell:
        """
        mkdir -p {RES_DIR} {PLOTS_DIR} {MPLCONFIG_DIR} {XDG_CACHE_DIR}
        export MPLCONFIGDIR="$PWD/{MPLCONFIG_DIR}"
        export XDG_CACHE_HOME="$PWD/{XDG_CACHE_DIR}"
        uv run --extra heatmap python scripts/compare_bpoints.py \
            --ours {input.ours} \
            --ref  {input.ref} \
            --output {output.tsv} \
            --plot {output.plot} \
            --require-exact
        """


rule compare_bed:
    input:
        ours = str(WORK_BED),
        ref  = str(REF_BED),
    output:
        tsv = str(RES_DIR / "compare_bed.tsv"),
        plot = str(PLOTS_DIR / "bed.svg"),
    shell:
        """
        mkdir -p {RES_DIR} {PLOTS_DIR} {MPLCONFIG_DIR} {XDG_CACHE_DIR}
        export MPLCONFIGDIR="$PWD/{MPLCONFIG_DIR}"
        export XDG_CACHE_HOME="$PWD/{XDG_CACHE_DIR}"
        uv run --extra heatmap python scripts/compare_bed.py \
            --ours {input.ours} \
            --ref  {input.ref} \
            --output {output.tsv} \
            --plot {output.plot} \
            --require-exact
        """


rule compare_staged_partitions:
    input:
        ours = str(WORK_PARTS),
        ref  = str(REF_PARTS),
    output:
        str(RES_DIR / "compare_staged_partitions.tsv"),
    shell:
        """
        uv run python scripts/compare_partitions.py \
            --ours {input.ours} \
            --ref  {input.ref} \
            --output {output} \
            --require-exact
        """


rule compare_generated_partitions:
    input:
        ours = str(WORK_GEN_PARTS),
        ref  = str(REF_PARTS),
    output:
        tsv = str(RES_DIR / "compare_generated_partitions.tsv"),
        plot = str(PLOTS_DIR / "generated_partitions.svg"),
    shell:
        """
        mkdir -p {RES_DIR} {PLOTS_DIR} {MPLCONFIG_DIR} {XDG_CACHE_DIR}
        export MPLCONFIGDIR="$PWD/{MPLCONFIG_DIR}"
        export XDG_CACHE_HOME="$PWD/{XDG_CACHE_DIR}"
        uv run --extra heatmap python scripts/compare_partitions.py \
            --ours {input.ours} \
            --ref  {input.ref} \
            --output {output.tsv} \
            --plot {output.plot}
        """
