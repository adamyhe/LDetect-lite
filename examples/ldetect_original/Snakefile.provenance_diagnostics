"""Targeted provenance diagnostics for ldetect_original divergences.

This workflow compares the current v3/all-variant input universe against
SNP-only and archived Phase 1 release candidates for only the divergent
chromosomes and configured controls.
"""

from pathlib import Path


configfile: "config.yaml"
configfile: "provenance_diagnostics.yaml"


RAW_ROOT = Path(config["raw_vcf_dir"]) / "provenance"
RES_ROOT = Path(config["resources_dir"]) / "provenance"
RESULTS = Path(config["results_dir"])
PROV_ROOT = RESULTS / "provenance_diagnostics"
FILT_ROOT = PROV_ROOT / "filtered_vcf"

POPS = [str(pop) for pop in config["diagnostic_populations"]]
CHROMS_BY_POP = {
    str(pop): [str(chrom) for chrom in chroms]
    for pop, chroms in config["chromosomes_by_population"].items()
}
BASELINE_SOURCE = str(config.get("baseline_source", "v3"))
BASELINE_FILTER = str(config.get("baseline_variant_filter", "all"))
COMPARISON_CANDIDATES = [
    (str(item["source"]), str(item["variant_filter"]))
    for item in config["comparison_candidates"]
]


def pop_subpops(population):
    return config["populations"][population]["subpops"]


def raw_vcf_path(dataset, chrom):
    return str(RAW_ROOT / dataset / f"chr{chrom}.vcf.gz")


def raw_tbi_path(dataset, chrom):
    return str(RAW_ROOT / dataset / f"chr{chrom}.vcf.gz.tbi")


def filtered_vcf_path(dataset, variant_filter, population, chrom):
    return str(
        FILT_ROOT
        / dataset
        / variant_filter
        / population
        / f"chr{chrom}.{population}.{variant_filter}.vcf.gz"
    )


def position_comparison_path(population, chrom, dataset, variant_filter):
    return str(
        PROV_ROOT
        / population
        / f"chr{chrom}"
        / "position_sets"
        / f"{dataset}_{variant_filter}_vs_{BASELINE_SOURCE}_{BASELINE_FILTER}.tsv"
    )


def ld_comparison_path(population, chrom, dataset, variant_filter):
    return str(
        PROV_ROOT
        / population
        / f"chr{chrom}"
        / "ld_sets"
        / f"{dataset}_{variant_filter}_vs_{BASELINE_SOURCE}_{BASELINE_FILTER}.tsv"
    )


def comparison_targets():
    targets = []
    for population in POPS:
        for chrom in CHROMS_BY_POP[population]:
            for dataset, variant_filter in COMPARISON_CANDIDATES:
                targets.append(
                    position_comparison_path(population, chrom, dataset, variant_filter)
                )
    return targets


def ld_comparison_targets():
    targets = []
    for population in POPS:
        for chrom in CHROMS_BY_POP[population]:
            for dataset, variant_filter in COMPARISON_CANDIDATES:
                targets.append(
                    ld_comparison_path(population, chrom, dataset, variant_filter)
                )
    return targets


rule all:
    input:
        str(PROV_ROOT / "position_comparison_summary.tsv"),
        str(PROV_ROOT / "ld_comparison_summary.tsv"),


rule download_source_vcf:
    output:
        vcf=str(RAW_ROOT / "{dataset}" / "chr{chrom}.vcf.gz"),
        tbi=str(RAW_ROOT / "{dataset}" / "chr{chrom}.vcf.gz.tbi"),
    shell:
        """
        uv run python scripts/download_provenance_input.py \
            --config provenance_diagnostics.yaml \
            --dataset {wildcards.dataset} \
            --kind vcf \
            --chromosome {wildcards.chrom} \
            --output {output.vcf}
        uv run python scripts/download_provenance_input.py \
            --config provenance_diagnostics.yaml \
            --dataset {wildcards.dataset} \
            --kind vcf-index \
            --chromosome {wildcards.chrom} \
            --output {output.tbi}
        """


rule download_source_panel:
    output:
        str(RES_ROOT / "{dataset}" / "panel.tsv"),
    shell:
        """
        uv run python scripts/download_provenance_input.py \
            --config provenance_diagnostics.yaml \
            --dataset {wildcards.dataset} \
            --kind panel \
            --output {output}
        """


rule prep_source_individuals:
    input:
        panel=rules.download_source_panel.output[0],
        vcf=lambda wc: raw_vcf_path(wc.dataset, 22),
        tbi=lambda wc: raw_tbi_path(wc.dataset, 22),
    output:
        str(RES_ROOT / "{dataset}" / "{population}_inds.txt"),
    params:
        subpops=lambda wc: " ".join(pop_subpops(wc.population)),
    shell:
        """
        uv run python scripts/prep_individuals.py \
            --panel {input.panel} \
            --subpops {params.subpops} \
            --vcf {input.vcf} \
            --output {output}
        """


rule filter_source_vcf:
    input:
        vcf=lambda wc: raw_vcf_path(wc.dataset, wc.chrom),
        tbi=lambda wc: raw_tbi_path(wc.dataset, wc.chrom),
        individuals=str(RES_ROOT / "{dataset}" / "{population}_inds.txt"),
    output:
        vcf=str(
            FILT_ROOT
            / "{dataset}"
            / "{variant_filter}"
            / "{population}"
            / "chr{chrom}.{population}.{variant_filter}.vcf.gz"
        ),
        tbi=str(
            FILT_ROOT
            / "{dataset}"
            / "{variant_filter}"
            / "{population}"
            / "chr{chrom}.{population}.{variant_filter}.vcf.gz.tbi"
        ),
    params:
        type_filter=lambda wc: "-v snps" if wc.variant_filter == "snps" else "",
    shell:
        """
        mkdir -p $(dirname {output.vcf})
        bcftools view -S {input.individuals} -Ou {input.vcf} \
            | bcftools view {params.type_filter} -i 'MAC[0]>=1' -m2 -M2 -Oz -o {output.vcf}
        tabix -f -p vcf {output.vcf}
        """


rule compare_position_sets:
    input:
        baseline=lambda wc: filtered_vcf_path(
            BASELINE_SOURCE, BASELINE_FILTER, wc.population, wc.chrom
        ),
        baseline_tbi=lambda wc: filtered_vcf_path(
            BASELINE_SOURCE, BASELINE_FILTER, wc.population, wc.chrom
        )
        + ".tbi",
        candidate=lambda wc: filtered_vcf_path(
            wc.dataset, wc.variant_filter, wc.population, wc.chrom
        ),
        candidate_tbi=lambda wc: filtered_vcf_path(
            wc.dataset, wc.variant_filter, wc.population, wc.chrom
        )
        + ".tbi",
        script="scripts/compare_vcf_positions.py",
    output:
        f"results/provenance_diagnostics/{{population}}/chr{{chrom}}/position_sets/{{dataset}}_{{variant_filter}}_vs_{BASELINE_SOURCE}_{BASELINE_FILTER}.tsv",
    params:
        baseline_label=f"{BASELINE_SOURCE}/{BASELINE_FILTER}",
        candidate_label=lambda wc: f"{wc.dataset}/{wc.variant_filter}",
    shell:
        """
        uv run python scripts/compare_vcf_positions.py \
            --population {wildcards.population} \
            --chromosome {wildcards.chrom} \
            --baseline-label {params.baseline_label} \
            --candidate-label {params.candidate_label} \
            --baseline-vcf {input.baseline} \
            --candidate-vcf {input.candidate} \
            --output {output}
        """


rule combine_position_comparisons:
    input:
        summaries=comparison_targets(),
        script="scripts/combine_tsv.py",
    output:
        str(PROV_ROOT / "position_comparison_summary.tsv"),
    shell:
        """
        uv run python scripts/combine_tsv.py \
            --input {input.summaries} \
            --output {output}
        """


rule compare_ld_sets:
    input:
        baseline=lambda wc: filtered_vcf_path(
            BASELINE_SOURCE, BASELINE_FILTER, wc.population, wc.chrom
        ),
        baseline_tbi=lambda wc: filtered_vcf_path(
            BASELINE_SOURCE, BASELINE_FILTER, wc.population, wc.chrom
        )
        + ".tbi",
        candidate=lambda wc: filtered_vcf_path(
            wc.dataset, wc.variant_filter, wc.population, wc.chrom
        ),
        candidate_tbi=lambda wc: filtered_vcf_path(
            wc.dataset, wc.variant_filter, wc.population, wc.chrom
        )
        + ".tbi",
        individuals=str(RES_ROOT / BASELINE_SOURCE / "{population}_inds.txt"),
        script="scripts/compare_vcf_ld.py",
    output:
        f"results/provenance_diagnostics/{{population}}/chr{{chrom}}/ld_sets/{{dataset}}_{{variant_filter}}_vs_{BASELINE_SOURCE}_{BASELINE_FILTER}.tsv",
    params:
        baseline_label=f"{BASELINE_SOURCE}/{BASELINE_FILTER}",
        candidate_label=lambda wc: f"{wc.dataset}/{wc.variant_filter}",
        window_bp=config.get("ld_window_bp", 5000),
        max_anchors=config.get("ld_max_anchors", 500),
        pairs_per_anchor=config.get("ld_pairs_per_anchor", 5),
    shell:
        """
        uv run python scripts/compare_vcf_ld.py \
            --population {wildcards.population} \
            --chromosome {wildcards.chrom} \
            --baseline-label {params.baseline_label} \
            --candidate-label {params.candidate_label} \
            --baseline-vcf {input.baseline} \
            --candidate-vcf {input.candidate} \
            --individuals {input.individuals} \
            --window-bp {params.window_bp} \
            --max-anchors {params.max_anchors} \
            --pairs-per-anchor {params.pairs_per_anchor} \
            --output {output}
        """


rule combine_ld_comparisons:
    input:
        summaries=ld_comparison_targets(),
        script="scripts/combine_tsv.py",
    output:
        str(PROV_ROOT / "ld_comparison_summary.tsv"),
    shell:
        """
        uv run python scripts/combine_tsv.py \
            --input {input.summaries} \
            --output {output}
        """
